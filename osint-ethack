}

_install_apt() {
  if [[ "$ENV" == "termux" ]]; then
    section "Installing Termux packages"
    pkg update -y -q
    local pkgs=(
      nmap curl git python3 pip ruby
      jq wget whois traceroute
      golang termux-tools openssh
    )
    for pkg in "${pkgs[@]}"; do
      info "Installing ${pkg}..."
      pkg install -y "$pkg" 2>&1 | tail -1 || warn "${pkg} not available"
    done
    ok "Termux packages done"
    warn "Note: masscan/gobuster/sqlmap not in Termux — use pip or go alternatives"
  else
    section "Installing APT tools"
    $SUDO apt update -qq
    local pkgs=(
      nmap masscan gobuster ffuf nikto amass
      whatweb wafw00f wpscan sqlmap
      hcxdumptool hcxtools netdiscover
      exploitdb tor proxychains4
      jq curl git python3-pip ruby bundler
      traceroute whois dnsx
    )
    for pkg in "${pkgs[@]}"; do
      info "Installing ${pkg}..."
      $SUDO apt install -y "$pkg" -qq 2>&1 | tail -1 || warn "${pkg} failed"
    done
    ok "APT tools done"
  fi
}

_install_pip() {
  section "Installing pip tools"
  pip_install holehe h8mail socialscan shodan maigret vulners
  ok "pip tools done"
}

_install_sherlock() {
