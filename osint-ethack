# ═══════════════════════════════════════════════════════════════
module_update() {
  banner
  section "UPDATE ALL TOOLS"
  echo -e "  ${Y}What to update:${NC}"
  local opts=(
    "Update apt tools (nmap, amass, subfinder...)"
    "Update pip tools (holehe, h8mail, socialscan...)"
    "Update git tools (sherlock, maigret, nuclei templates...)"
    "Update ALL"
    "Back"
  )
  PS3=$'\n  Choose [1-5]: '
  select opt in "${opts[@]}"; do
    case $REPLY in
      1) _update_apt ;;
      2) _update_pip ;;
      3) _update_git ;;
      4) _update_apt; _update_pip; _update_git ;;
      5) return ;;
    esac
    break
  done
}

_update_apt() {
  section "Updating APT tools"
  local pkgs=(
    nmap masscan gobuster ffuf nikto amass
    whatweb wafw00f wpscan sqlmap theHarvester
    hcxdumptool netdiscover exploitdb
    tor proxychains4 jq curl python3-pip
  )
  apt update -qq
  for pkg in "${pkgs[@]}"; do
    if dpkg -l "$pkg" &>/dev/null; then
      info "Upgrading ${pkg}..."
      apt install --only-upgrade -y "$pkg" -qq 2>&1 | grep -v "^$" || true
      ok "${pkg} up to date"
    fi
  done
}

_update_pip() {
  section "Updating pip tools"
  local pips=(holehe h8mail socialscan shodan maigret phoneinfoga vulners)
  for p in "${pips[@]}"; do
    if pip3 show "$p" &>/dev/null; then
      info "Upgrading ${p}..."
      pip_install --upgrade "$p" && ok "${p} updated"
    fi
  done
}

_update_git() {
  section "Updating git-cloned tools"
  local repos=(
    "sherlock"
    "maigret"
    "nuclei-templates"
    "intelx"
    "phoneinfoga"
    "subfinder"
    "WebSift"
    "spiderfoot"
    "GhostTrack"
    "DaProfiler"
    "XSSRecon"
    "Sn1per"
    "xosint"
    "ClatScope"
    "fsociety"
  )
  for repo in "${repos[@]}"; do
    local rpath="${TOOLS_DIR}/${repo}"
    if [[ -d "${rpath}/.git" ]]; then
      info "Updating ${repo}..."
      git -C "$rpath" pull --rebase --autostash -q && ok "${repo} updated"
    fi
  done

  # Update nuclei templates specifically
  if command -v nuclei &>/dev/null; then
    info "Updating nuclei templates..."
    nuclei -update-templates -silent && ok "Nuclei templates updated"
  fi
}

