  read -rp "  ${C}Target URL (e.g. https://target.com): ${NC}" URL
  [[ -z "$URL" ]] && return

  local host
  host=$(echo "$URL" | awk -F/ '{print $3}')
  local outdir="${WORKDIR}/webapp_${host}_$(timestamp)"
  mkdir -p "$outdir"

  echo -e "\n  ${Y}Select tool:${NC}"
  local opts=(
    "whatweb        — technology fingerprinting"
    "wafw00f        — WAF detection"
    "nikto          — web server vulnerability scan"
    "gobuster       — directory/file bruteforce"
    "ffuf           — fast web fuzzer"
    "nuclei         — template-based vuln scanner"
    "wpscan         — WordPress scanner"
    "sqlmap         — SQL injection"
    "XSSRecon       — automated XSS scanner"
    "Sn1per         — full attack surface management"
    "fsociety       — modular pentest framework wrapper"
    "Back"
