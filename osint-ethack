#  MODULE 10 — CONFIG
# ═══════════════════════════════════════════════════════════════
module_config() {
  banner
  section "CONFIGURATION"
  echo -e "  ${DIM}Config file: ${CONF}${NC}"
  echo
  load_config
  echo -e "  Current settings:"
  echo -e "  Shodan API Key : ${SHODAN_API_KEY:-${R}not set${NC}}"
  echo -e "  VT API Key     : ${VT_API_KEY:-${R}not set${NC}}"
  echo -e "  NVD Feed Days  : ${NVD_FEEDS_DAYS:-7}"
  echo

  echo -e "  ${Y}Edit setting:${NC}"
  local opts=(
    "Set Shodan API key"
    "Set VirusTotal API key"
    "Set NVD feed days (default 7)"
    "Edit config file (nano)"
    "Back"
  )
  PS3=$'\n  Choose [1-5]: '
  select opt in "${opts[@]}"; do
    case $REPLY in
      1) read -rp "  Shodan API Key: " k
         sed -i "s/SHODAN_API_KEY=.*/SHODAN_API_KEY=\"${k}\"/" "$CONF"; ok "Saved" ;;
      2) read -rp "  VT API Key: " k
         sed -i "s/VT_API_KEY=.*/VT_API_KEY=\"${k}\"/" "$CONF"; ok "Saved" ;;
      3) read -rp "  Days: " d
         sed -i "s/NVD_FEEDS_DAYS=.*/NVD_FEEDS_DAYS=${d}/" "$CONF"; ok "Saved" ;;
      4) nano "$CONF" ;;
      5) return ;;
    esac
    break
  done
}

# ═══════════════════════════════════════════════════════════════
#  MODULE 11 — VIEW LOGS
# ═══════════════════════════════════════════════════════════════
module_logs() {
  banner
  section "SAVED RESULTS"
  echo -e "  ${DIM}Logs dir: ${LOGS_DIR}${NC}"
  echo -e "  ${DIM}Work dir: ${WORKDIR}${NC}"
  echo
  if ! ls "${LOGS_DIR}"/*.txt &>/dev/null && ! ls "${WORKDIR}" &>/dev/null; then
    info "No results yet."
    pause
    return
  fi

  if command -v fzf &>/dev/null; then
    local chosen
    chosen=$(find "${LOGS_DIR}" "${WORKDIR}" -type f -name "*.txt" 2>/dev/null \
      | fzf --height=60% --border --prompt="  Select file: ")
    [[ -n "$chosen" ]] && less "$chosen"
  else
    ls -lt "${LOGS_DIR}"/*.txt 2>/dev/null | head -20
    echo
    read -rp "  ${C}View file (full path or Enter to skip): ${NC}" f
    [[ -n "$f" && -f "$f" ]] && less "$f"
  fi
}

