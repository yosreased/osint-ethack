  echo -e "  ${Y}Edit setting:${NC}"
  local opts=(
    "Set Shodan API key"
    "Set VirusTotal API key"
    "Set NVD feed days (default 7)"
    "Edit config file (nano)"
    "Back"
  )
  PS3=$'\n  Choose [1-5]: '
  select opt in "${opts[@]}"; do
