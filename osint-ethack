  select opt in "${opts[@]}"; do
    case $REPLY in
      1) require whatweb   && whatweb "$URL" -v | tee "${outdir}/whatweb.txt" ;;
      2) require wafw00f   && wafw00f "$URL" | tee "${outdir}/waf.txt" ;;
      3) require nikto     && nikto -h "$URL" -o "${outdir}/nikto.txt" ;;
      4) _gobuster "$URL" "$outdir" ;;
      5) _ffuf "$URL" "$outdir" ;;
      6) _nuclei "$URL" "$outdir" ;;
      7) require wpscan    && wpscan --url "$URL" --enumerate ap,at,u | tee "${outdir}/wpscan.txt" ;;
      8) require sqlmap    && sqlmap -u "$URL" --batch --level=3 | tee "${outdir}/sqlmap.txt" ;;
      9) _xssrecon "$URL" "$outdir" ;;
