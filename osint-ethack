  curl -s -X POST "https://mb-api.abuse.ch/api/v1/"     -H "Content-Type: application/json"     -d "$query"     | jq -r '.data[]? | "\(.sha256_hash)  \(.file_name)  [\(.tags[]?)]  \(.signature)"'     | head -20 | tee "${LOGS_DIR}/malwarebazaar_$(timestamp).txt"
