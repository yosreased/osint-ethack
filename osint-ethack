# ═══════════════════════════════════════════════════════════════
#  MODULE 2 — EXPLOIT & ZERO-DAY INTEL
# ═══════════════════════════════════════════════════════════════
module_exploit_intel() {
  banner
  section "EXPLOIT & ZERO-DAY INTEL"
  echo -e "  ${Y}Select source:${NC}"
  local opts=(
    "CVE NVD Feed        — latest CVEs from NIST (offline JSON)"
    "ExploitDB search    — searchsploit local + online"
    "Metasploit modules  — search MSF for exploits"
    "PoC-in-GitHub       — find CVE PoCs on GitHub"
    "Vulners CLI         — vuln scanner & CVE lookup"
    "PacketStorm feed    — latest advisories (curl)"
    "CISA KEV feed       — known exploited vulnerabilities"
    "TweetFeed IOC       — live IOCs from infosec community"
    "CVE GitHub Scraper  — all CVE exploits from GitHub"
    "Back"
  )
  PS3=$'\n  Choose [1-10]: '
  select opt in "${opts[@]}"; do
    case $REPLY in
      1) _nvd_feed ;;
      2) _exploitdb ;;
      3) _msf_search ;;
      4) _poc_github ;;
      5) _vulners ;;
      6) _packetstorm ;;
      7) _cisa_kev ;;
      8) _tweetfeed_ioc ;;
      9) _cve_github_scraper ;;
      10) return ;;
    esac
    break
  done
}

_nvd_feed() {
  require curl || return
  require jq   || return
  local days="${NVD_FEEDS_DAYS:-7}"
  local end_date start_date
  end_date=$(date -u '+%Y-%m-%dT%H:%M:%S.000')
  start_date=$(date -u -d "${days} days ago" '+%Y-%m-%dT%H:%M:%S.000' 2>/dev/null \
    || date -u -v-"${days}"d '+%Y-%m-%dT%H:%M:%S.000')

  info "Fetching NVD CVEs from last ${days} days..."
  local url="https://services.nvd.nist.gov/rest/json/cves/2.0?pubStartDate=${start_date}&pubEndDate=${end_date}&resultsPerPage=20"
  
  curl -s "$url" | jq -r '
    .vulnerabilities[] |
    "\(.cve.id)  CVSS:\(.cve.metrics.cvssMetricV31[0].cvssData.baseScore // .cve.metrics.cvssMetricV2[0].cvssData.baseScore // "N/A")  \(.cve.descriptions[0].value[:80])"
  ' 2>/dev/null | sort -t: -k2 -rn | head -30 | tee "${LOGS_DIR}/nvd_$(timestamp).txt"

  echo
  read -rp "  ${C}Search specific CVE ID (e.g. CVE-2024-1234) or Enter to skip: ${NC}" cveid
  if [[ -n "$cveid" ]]; then
    curl -s "https://services.nvd.nist.gov/rest/json/cves/2.0?cveId=${cveid}" \
      | jq -r '.vulnerabilities[0] | 
        "ID: \(.cve.id)\nPublished: \(.cve.published)\nScore: \(.cve.metrics.cvssMetricV31[0].cvssData.baseScore // "N/A")\nSeverity: \(.cve.metrics.cvssMetricV31[0].cvssData.baseSeverity // "N/A")\nDesc: \(.cve.descriptions[0].value)\nRefs:\n\(.cve.references[].url)"
      ' 2>/dev/null | tee "${LOGS_DIR}/${cveid}_$(timestamp).txt"
  fi
  pause
}

_exploitdb() {
  require searchsploit || { warn "Install: apt install exploitdb"; return; }
  read -rp "  ${C}Search term (e.g. 'apache 2.4 rce'): ${NC}" term
  [[ -z "$term" ]] && return
  info "Searching ExploitDB..."
  searchsploit "$term" | tee "${LOGS_DIR}/edb_$(timestamp).txt"
  echo
  read -rp "  ${C}View full exploit? Enter EDB-ID or Enter to skip: ${NC}" edbid
  [[ -n "$edbid" ]] && searchsploit -x "$edbid"
  pause
}

_msf_search() {
  require msfconsole || { warn "Metasploit not found."; return; }
  read -rp "  ${C}Search term (e.g. 'eternalblue'): ${NC}" term
  [[ -z "$term" ]] && return
  info "Searching Metasploit modules..."
  msfconsole -q -x "search $term; exit" 2>/dev/null | tee "${LOGS_DIR}/msf_$(timestamp).txt"
  pause
}

_poc_github() {
  require curl || return
  require jq   || return
  read -rp "  ${C}Enter CVE ID (e.g. CVE-2024-1234): ${NC}" cveid
  [[ -z "$cveid" ]] && return
  info "Searching GitHub for PoCs: ${cveid}..."
  curl -s "https://api.github.com/search/repositories?q=${cveid}+PoC&sort=updated&per_page=10" \
    | jq -r '.items[] | "\(.full_name)  ★\(.stargazers_count)  \(.html_url)"' \
    | tee "${LOGS_DIR}/poc_${cveid}_$(timestamp).txt"
  
  echo
  info "Also checking: https://github.com/trickest/cve (CVE PoC repo)"
  info "And: https://github.com/nomi-sec/PoC-in-GitHub"
  pause
}

_vulners() {
  require curl || return
  require jq   || return
  read -rp "  ${C}Software + version (e.g. 'Apache 2.4.50'): ${NC}" sw
  [[ -z "$sw" ]] && return
  info "Querying Vulners API..."
  curl -s "https://vulners.com/api/v3/search/lucene/?query=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$sw")&size=10" \
    | jq -r '.data.search[] | "\(.cvss.score // "N/A")  \(._id)  \(.title)"' 2>/dev/null \
    | sort -rn \
    | tee "${LOGS_DIR}/vulners_$(timestamp).txt"
  pause
}

_packetstorm() {
  require curl || return
  info "Fetching PacketStorm latest advisories..."
  curl -s "https://packetstormsecurity.com/feeds/news" \
    | grep -oP '(?<=<title>)[^<]+' \
    | head -20 \
    | nl \
    | tee "${LOGS_DIR}/packetstorm_$(timestamp).txt"
  pause
}

_cisa_kev() {
  require curl || return
  require jq   || return
  info "Fetching CISA Known Exploited Vulnerabilities catalog..."
  curl -s "https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json" \
    | jq -r '.vulnerabilities | sort_by(.dateAdded) | reverse | .[0:25][] |
      "\(.dateAdded)  \(.cveID)  [\(.product)]  \(.shortDescription[:60])"' \
    | tee "${LOGS_DIR}/cisa_kev_$(timestamp).txt"
  echo
  ok "Full catalog: https://www.cisa.gov/known-exploited-vulnerabilities-catalog"
  pause
}

_tweetfeed_ioc() {
  require curl || return
  require jq   || return
  info "Fetching live IOCs from TweetFeed (infosec community)..."
  echo
  echo -e "  ${Y}[URLs]${NC}"
  curl -s "https://api.tweetfeed.live/v1/today/urls"     | jq -r '.[] | "\(.date)  \(.value)  [\(.tags[]?)]"' 2>/dev/null     | head -15 | tee "${LOGS_DIR}/ioc_urls_$(timestamp).txt"
  echo
  echo -e "  ${Y}[Malicious IPs]${NC}"
  curl -s "https://api.tweetfeed.live/v1/today/ip"     | jq -r '.[] | "\(.date)  \(.value)  [\(.tags[]?)]"' 2>/dev/null     | head -15 | tee "${LOGS_DIR}/ioc_ips_$(timestamp).txt"
  echo
  echo -e "  ${Y}[Hashes]${NC}"
  curl -s "https://api.tweetfeed.live/v1/today/sha256"     | jq -r '.[] | "\(.date)  \(.value)"' 2>/dev/null     | head -10 | tee "${LOGS_DIR}/ioc_hashes_$(timestamp).txt"
  pause
}

_cve_github_scraper() {
  require curl || return
  require jq   || return
  read -rp "  ${C}CVE ID (e.g. CVE-2024-1234) or year (e.g. 2024): ${NC}" input
  [[ -z "$input" ]] && return
  info "Searching GitHub for CVE exploits: ${input}..."
  curl -s "https://api.github.com/search/repositories?q=${input}+exploit+CVE&sort=updated&per_page=15"     | jq -r '.items[] | "\(.updated_at[:10])  ★\(.stargazers_count)  \(.full_name)  \(.html_url)"'     | sort -r | tee "${LOGS_DIR}/cve_scraper_${input}_$(timestamp).txt"
  echo
  info "Also check: https://github.com/search?q=${input}+exploit&type=repositories"
  pause
}

# ═══════════════════════════════════════════════════════════════
#  MODULE 3 — NETWORK & HOST INTEL
# ═══════════════════════════════════════════════════════════════
module_network_intel() {
  banner
  section "NETWORK & HOST INTEL"
  read -rp "  ${C}Target IP/range (e.g. 192.168.1.0/24 or 1.2.3.4): ${NC}" TARGET
  [[ -z "$TARGET" ]] && return

  local outdir="${WORKDIR}/net_${TARGET//\//_}_$(timestamp)"
  mkdir -p "$outdir"

  echo -e "\n  ${Y}Select scan:${NC}"
  local opts=(
    "nmap — quick host discovery"
    "nmap — full port + version + scripts"
    "nmap — vuln scripts (--script vuln)"
    "nmap — stealth SYN scan"
    "masscan — fast all-ports"
    "netdiscover — ARP local scan"
    "traceroute + ASN lookup"
    "Back"
  )
  PS3=$'\n  Choose [1-8]: '
  select opt in "${opts[@]}"; do
    case $REPLY in
      1) nmap -sn "$TARGET" -oN "${outdir}/discover.txt" | tee /dev/tty ;;
      2) nmap -sV -sC -p- --open "$TARGET" -oN "${outdir}/full.txt" | tee /dev/tty ;;
      3) nmap --script vuln "$TARGET" -oN "${outdir}/vuln.txt" | tee /dev/tty ;;
      4) nmap -sS -Pn -T4 "$TARGET" -oN "${outdir}/stealth.txt" | tee /dev/tty ;;
      5) _masscan "$TARGET" "$outdir" ;;
      6) _netdiscover "$TARGET" "$outdir" ;;
      7) _traceroute_asn "$TARGET" "$outdir" ;;
      8) return ;;
    esac
    ok "Results saved → ${outdir}/"
    break
  done
  pause
}

_masscan() {
  require masscan || { warn "Install: apt install masscan"; return; }
  info "masscan on $1 (all ports, rate 1000)..."
  masscan "$1" -p1-65535 --rate=1000 -oL "${2}/masscan.txt"
}

_netdiscover() {
  require netdiscover || { warn "Install: apt install netdiscover"; return; }
  info "ARP scan..."
  netdiscover -r "$1" -P | tee "${2}/netdiscover.txt"
}

_traceroute_asn() {
  require traceroute || return
  require curl || return
  info "Traceroute to $1..."
  traceroute "$1" | tee "${2}/traceroute.txt"
  info "ASN lookup..."
  curl -s "https://ipinfo.io/${1}/org" | tee -a "${2}/traceroute.txt"
  echo
}

# ═══════════════════════════════════════════════════════════════
#  MODULE 4 — PEOPLE & IDENTITY OSINT
# ═══════════════════════════════════════════════════════════════
module_people_osint() {
  banner
